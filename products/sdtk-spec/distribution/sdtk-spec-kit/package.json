{
    "name": "sdtk-spec-kit",
    "version": "0.4.4",
    "description": "SDTK-SPEC CLI toolkit for deterministic software documentation workflows via the sdtk-spec command",
    "bin": {
        "sdtk-spec": "bin/sdtk.js"
    },
    "main": "src/index.js",
    "type": "commonjs",
    "files": [
        "bin/",
        "src/",
        "assets/"
    ],
    "scripts": {
        "test": "npm run verify:payload && npm run pack:smoke",
        "build:payload": "powershell -ExecutionPolicy Bypass -File scripts/sync-toolkit-assets.ps1 && powershell -ExecutionPolicy Bypass -File scripts/build-toolkit-manifest.ps1",
        "verify:payload": "node -e \"require('./src/lib/toolkit-payload').verify()\"",
        "pack:smoke": "npm pack --dry-run",
        "pack:release": "npm pack",
        "prepublishOnly": "node -e \"require('./src/lib/toolkit-payload').verify()\""
    },
    "engines": {
        "node": ">=18.13.0"
    },
    "keywords": [
        "sdtk",
        "sdtk-spec",
        "sdtk-spec-kit",
        "cli",
        "documentation",
        "toolkit",
        "dockkit"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/codexsdtk/sdtk-toolkit.git",
        "directory": "products/sdtk-spec/distribution/sdtk-spec-kit"
    },
    "homepage": "https://sdtk.dev",
    "bugs": {
        "url": "https://github.com/codexsdtk/sdtk-toolkit/issues"
    },
    "publishConfig": {
        "access": "public"
    }
}
